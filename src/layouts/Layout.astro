---
// Import font dan global CSS
import "@fontsource/vt323/400.css";
import "@fontsource/press-start-2p/400.css";
import "@/styles/global.css";
import bgImage from '../assets/SuikodenBackground.png';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portofolio Interaktif ala JRPG" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <!-- Menggunakan font VT323 sebagai default agar teks mudah terbaca tapi tetap retro -->
  <body
    class="bg-zinc-950 text-slate-100 font-vt323 text-2xl antialiased selection:bg-suikoden-blue selection:text-white"
    style={`background-image: url(${bgImage.src}); background-size: cover; background-position: center; background-attachment: fixed;`}
  >
    <main class="max-w-5xl mx-auto px-4 md:px-8">
      <div class="bg-black/50 backdrop-blur-lg rounded-lg py-10 md:py-14 px-6">
        <slot />
      </div>
    </main>
  </body>
</html>