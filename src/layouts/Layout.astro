---
// Import font dan global CSS
import "@fontsource/vt323/400.css";
import "@fontsource/press-start-2p/400.css";
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portofolio Interaktif ala JRPG" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <!-- Menggunakan font VT323 sebagai default agar teks mudah terbaca tapi tetap retro -->
  <body class="bg-zinc-950 text-slate-100 min-h-screen font-vt323 text-2xl antialiased selection:bg-suikoden-blue selection:text-white">
    <main class="max-w-5xl mx-auto p-4 md:p-8">
      <slot />
    </main>
  </body>
</html>